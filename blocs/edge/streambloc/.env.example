COMPOSE_PROJECT_NAME=streambloc
TZ=America/New_York

# Set this to the Tiny LAN IP. Use AccessBloc/Tailscale for secure remote access.
JELLYFIN_BIND_IP=10.0.0.187
JELLYFIN_HTTP_PORT=8096
JELLYFIN_VERSION=latest

# Persistent host paths.
STREAMBLOC_ROOT=/srv/streambloc
MEDIA_ROOT=/srv/media

# Intel QuickSync group ids vary by distro.
# Check with: getent group video && getent group render
VIDEO_GID=44
RENDER_GID=109
